# GitHub OAuth App credentials
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Dedicated signing secret for user session cookies
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# Admin panel password
ADMIN_PASSWORD=your_admin_password

# Dedicated signing secret for admin session + admin CSRF tokens
# Generate with: openssl rand -hex 32
ADMIN_SESSION_SECRET=

# Hash pepper for user identity derivation (HMAC key, keep secret!)
# Generate with: openssl rand -hex 32
HASH_PEPPER=

# SQLite database path (default: data/aipocalypse.db)
DATABASE_PATH=data/aipocalypse.db
